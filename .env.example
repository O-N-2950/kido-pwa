# VIVOKID — Environment Variables
# Copy to .env for local development

# ── Database (Railway PostgreSQL) ─────────────────────────────
DATABASE_URL=postgresql://user:password@host:5432/vivokid

# ── Auth ──────────────────────────────────────────────────────
JWT_SECRET=change-me-in-production-min-32-chars

# ── Email SMTP Infomaniak ─────────────────────────────────────
SMTP_HOST=mail.infomaniak.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=contact@vivokid.ch
SMTP_PASS=353ny!3Y$rreBVJH
EMAIL_FROM=contact@vivokid.ch
EMAIL_FROM_NAME=VIVOkid

# ── Resend (fallback) ─────────────────────────────────────────
RESEND_API_KEY=re_...

# ── Stripe ───────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ── Firebase (Push notifications) ────────────────────────────
FIREBASE_PROJECT_ID=vivokid
FIREBASE_PRIVATE_KEY=...
FIREBASE_CLIENT_EMAIL=...

# ── AI ────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
DEEPGRAM_API_KEY=...

# ── App ───────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development
CLIENT_URL=http://localhost:5173
APP_URL=https://vivokid.ch
APP_NAME=VIVOkid

